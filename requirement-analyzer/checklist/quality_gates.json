{
  "name": "质量门槛检查清单",
  "version": "1.0.0",
  "description": "检查需求是否具备必要的非功能约束和验收条件",
  "categories": {
    "non_functional": {
      "name": "非功能要求",
      "questions": [
        {
          "id": "NFR-01",
          "question": "是否定义了性能或 SLA 目标？",
          "fields": ["场景", "指标", "阈值"]
        },
        {
          "id": "NFR-02",
          "question": "是否明确了权限、角色或责任边界？",
          "fields": ["主体", "操作权限", "边界条件"]
        },
        {
          "id": "NFR-03",
          "question": "是否定义了幂等、重试、补偿或恢复要求？",
          "fields": ["触发场景", "处理策略", "恢复方式"]
        },
        {
          "id": "NFR-04",
          "question": "是否定义了监控、审计和告警要求？",
          "fields": ["指标", "日志/审计", "告警规则"]
        },
        {
          "id": "NFR-05",
          "question": "是否说明了兼容性、迁移、发布或回滚要求？",
          "fields": ["兼容范围", "迁移要求", "发布策略", "回滚方案"]
        }
      ]
    },
    "acceptance": {
      "name": "验收条件",
      "questions": [
        {
          "id": "ACC-01",
          "question": "是否存在可验证的验收标准？",
          "fields": ["验收场景", "预期结果", "判定方式"]
        },
        {
          "id": "ACC-02",
          "question": "是否定义了成功指标或完成标准？",
          "fields": ["指标名称", "目标值", "统计口径"]
        },
        {
          "id": "ACC-03",
          "question": "是否明确了谁负责确认验收通过？",
          "fields": ["确认方", "确认方式", "确认时点"]
        }
      ]
    }
  },
  "usage": {
    "description": "这些问题用于识别需求是否具备足够的工程落地约束，不要求 PRD 提供实现细节，但应至少明确目标和边界。",
    "status_codes": {
      "✅": "已明确",
      "⚠️": "部分明确，建议补充",
      "❌": "未明确，可能影响设计或上线",
      "N/A": "当前场景不适用"
    }
  }
}
